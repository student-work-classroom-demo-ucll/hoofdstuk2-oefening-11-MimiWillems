<Window x:Class="oefening2._1_startercode.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:oefening2._1_startercode"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button x:Name="btnOne" Content="1" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="50" Click="btnOne_Click" x:FieldModifier="public"/>
        <Button x:Name="btnTwo" Content="2" HorizontalAlignment="Left" Margin="80,10,0,0" VerticalAlignment="Top" Width="50" Click="btnTwo_Click" x:FieldModifier="public"/>
        <Button x:Name="btnThree" Content="3" HorizontalAlignment="Left" Margin="149,10,0,0" VerticalAlignment="Top" Width="50" Click="btnThree_Click" x:FieldModifier="public"/>
        <Label x:Name="lblOne" Content="Label" HorizontalAlignment="Left" Margin="10,61,0,0" VerticalAlignment="Top" x:FieldModifier="public"/>
        <Label x:Name="lblTwo" Content="Label" HorizontalAlignment="Left" Margin="80,61,0,0" VerticalAlignment="Top" x:FieldModifier="public"/>
        <Label x:Name="lblThree" Content="Label" HorizontalAlignment="Left" Margin="149,61,0,0" VerticalAlignment="Top" x:FieldModifier="public"/>
    </Grid>
</Window>
